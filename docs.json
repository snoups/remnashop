    "logo": "/logo.svg",
    "navbar": {
        "links": [
            {
                "label": "Telegram",
                "href": "https://t.me/remnashop"
            },
            {
                "label": "GitHub",
                "href": "https://github.com/snoups/remnashop"
            }
        ],
        "primary": {
            "type": "button",
            "label": "Dashboard",
            "href": "https://dashboard.mintlify.com"
        }
    },
    "contextual": {
        "options": [
            "copy",
            "view",
            "chatgpt",
            "claude",
            "perplexity",
            "mcp",
            "cursor",
            "vscode"
        ]
    },
