        "strict": true
    },
    "interaction": {
        "drilldown": false
    },
    "banner": {
        "dismissible": false,
        "content": "Remnashop"
    },
    "thumbnails": {
        "appearance": "dark"
    },
    "styling": {
        "codeblocks": "dark"
    },
    "icons": {
        "library": "tabler"
    },
    "api": {
        "playground": {
            "proxy": false
        }
    },
    "favicon": "/favicon.svg"
