{
    "$schema": "https://mintlify.com/docs.json",
    "theme": "mint",
    "name": "Remnashop",
    "colors": {
        "primary": "#22D3EE",
        "light": "#22D3EE",
        "dark": "#161b22"
    },
    "navigation": {
      "languages": [
        {
          "language": "ru",
          "groups": [
            {
              "group": "Обзор",
              "pages": [
                "docs/ru/overview/releases",
                "docs/ru/overview/introduction",
                "docs/ru/overview/support"
              ]
            },
            {
              "group": "Начало",
              "pages": [
                "docs/ru/install/requirements",
                "docs/ru/install/installation",
                "docs/ru/install/environment-variables",
                "docs/ru/install/assets",
                "docs/ru/install/update"
              ]
            },
            {
            "group": "Реверс прокси",
            "root": "docs/ru/reverse-proxies",
            "pages": [
              "docs/ru/reverse-proxies/caddy",
              "docs/ru/reverse-proxies/nginx",
              "docs/ru/reverse-proxies/traefik"
            ]
            }
          ]
        },
        {
          "language": "en",
          "groups": [
            {
              "group": "Overview",
              "pages": [
                "docs/en/overview/releases",
                "docs/en/overview/introduction",
                "docs/en/overview/support"
              ]
            },
            {
              "group": "Getting Started",
              "pages": [
                "docs/en/install/requirements",
                "docs/en/install/installation",
                "docs/en/install/environment-variables",
                "docs/en/install/assets",
                "docs/en/install/update"
              ]
            },
            {
              "group": "Reverse Proxies",
              "root": "docs/en/reverse-proxies",
              "pages": [
                "docs/en/reverse-proxies/caddy",
                "docs/en/reverse-proxies/nginx",
                "docs/en/reverse-proxies/traefik"
              ]
            }
          ]
        }
      ]
    },
    "logo": "/logo.svg",
    "navbar": {
        "links": [
            {
                "label": "Telegram",
                "href": "https://t.me/remnashop"
            },
            {
                "label": "GitHub",
                "href": "https://github.com/snoups/remnashop"
            }
        ],
        "primary": {
            "type": "button",
            "label": "Dashboard",
            "href": "https://dashboard.mintlify.com"
        }
    },
    "contextual": {
        "options": [
            "copy",
            "view",
            "chatgpt",
            "claude",
            "perplexity",
            "mcp",
            "cursor",
            "vscode"
        ]
    },
    "footer": {
        "socials": {
            "github": "https://github.com/snoups/remnashop"
        }
    },
    "background": {
        "color": {
            "dark": "#161b22",
            "light": "#161b22"
        },
        "decoration": "grid"
    },
    "appearance": {
        "default": "dark",
        "strict": true
    },
    "interaction": {
        "drilldown": false
    },
    "thumbnails": {
        "appearance": "dark"
    },
    "styling": {
        "codeblocks": "dark"
    },
    "icons": {
        "library": "tabler"
    },
    "api": {
        "playground": {
            "proxy": false
        }
    },
    "favicon": "/favicon.svg"
}
